{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quill",
  "version": "0.1.0",
  "identifier": "com.eoghancollins.quill",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "mimeType": "text/markdown",
        "description": "Markdown Document",
        "role": "Editor",
        "rank": "Owner",
        "exportedType": {
          "identifier": "com.eoghancollins.quill.markdown",
          "conformsTo": ["public.text", "public.data"]
        }
      },
      {
        "ext": ["txt"],
        "mimeType": "text/plain",
        "description": "Text Document",
        "role": "Editor"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "infoPlist": "Info.plist"
    }
  }
}
