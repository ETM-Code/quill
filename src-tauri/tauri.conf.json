{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quill",
  "version": "0.1.0",
  "identifier": "com.eoghancollins.quill",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Quill",
        "width": 900,
        "height": 700,
        "minWidth": 400,
        "minHeight": 300,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "mimeType": "text/markdown",
        "description": "Markdown Document",
        "role": "Editor"
      },
      {
        "ext": ["txt"],
        "mimeType": "text/plain",
        "description": "Text Document",
        "role": "Editor"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
